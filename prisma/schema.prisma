generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum RewardType {
  STARS
  XP
}

enum DailyRewardType {
  ITEM
  STARS
  XP
  PARTS
  GEAR
}

enum RuneType {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum TransactionStatus {
  INITIATED
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum TransactionType {
  PACK
  ALIEN_PART
  STARS
  XP
  REP
}

enum CharacterTransactionType {
  MINT
  BURN
}

enum ElementType {
  GAMMA
  FIRE
  LIFE
  WATER
  LOVE
  GRAVITY
  PLASMA
  THUNDER
}

enum ItemType {
  SHEARS
  CUT
  KNIFE
}

enum ItemQuality {
  BRONZE
  SILVER
  GOLDEN
}

model User {
  id                    Int                    @id @default(autoincrement())
  walletAddress         String                 @unique
  name                  String
  country               String
  twitterId             String?
  enterprise            String
  referralCode          String                 @unique
  referrerId            Int?
  image                 String
  level                 Int                    @default(1)
  experience            Int
  reputation            Int
  stars                 Int
  RaidHistory           RaidHistory[]
  aliens                Alien[]
  characterIds          Int[]                 @default([])
  teamCharacterIds      Int[]                 @default([])
  teamAlienIds          Int[]                 @default([])
  raidAlienIds          Int[]                 @default([])
  raidCharacterIds      Int[]                 @default([])
  unmintedCharacters    UnmintedCharacter[]
  items                 UserItem[]
  runes                 RuneType[]
  starsBoost            Int                    @default(0)
  raidTimeBoost         Int                    @default(0)
  xpBoost               Int                    @default(0)
  lastStarBoost         DateTime?
  lastRaidBoost         DateTime?
  lastXpBoost           DateTime?
  role                  Role                   @default(USER)
  dailyStreak           Int                    @default(0)
  lastDailyClaimed      DateTime?               
  claimedDailyRewards   DailyReward[]
  claimedDailyRewardIds Int[]                  @default([])
  likedUserIds          Int[]                  @default([])
  lastDailyLogin        DateTime               @default(now())
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  referrerRewards       ReferralReward[]       @relation("ReferrerRewards")
  refereeRewards        ReferralReward[]       @relation("RefereeRewards")
  transactions          Transaction[]
  AlienParts            AlienPart[]
  AlienPartGroups       AlienPartGroup[]
  purchasedPacks        Pack[]           @relation("PurchasedPacks")
  gearItems             UserGearItem[]
  UserElement           UserElement[]
  characterTransactions CharacterTransaction[]
  UserSpin              UserSpin[]
  userQuests            UserQuest[]
  sentMessages          Message[]       @relation("SentMessages")
  receivedMessages      Message[]       @relation("ReceivedMessages")
  friendships           Friendship[]    @relation("UserFriendships")
  friendUserFriendships Friendship[]    @relation("FriendUserFriendships")
}

model Raid {
  id          Int           @id @default(autoincrement())
  title       String
  description String
  duration    Int
  image       String
  rewards     RaidReward[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  RaidHistory RaidHistory[]
  element     Element       @relation(fields: [elementId], references: [id])
  elementId   Int
  isHunt      Boolean      @default(false)
}

model RaidReward {
  id        Int        @id @default(autoincrement())
  type      RewardType
  amount    Int
  raids     Raid[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model RaidHistory {
  id                Int             @id @default(autoincrement())
  raid              Raid            @relation(fields: [raidId], references: [id])
  raidId            Int
  user              User            @relation(fields: [userId], references: [id])
  userId            Int
  aliens            Alien[]
  characterIds      Int[]
  inProgress        Boolean         @default(true)
  raidFinishTime    DateTime
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([raidId, userId])
}

model Alien {
  id             Int           @id @default(autoincrement())
  name           String
  image          String?
  strengthPoints Int
  equipmentPower Int
  user           User          @relation(fields: [userId], references: [id])
  userId         Int
  selected       Boolean       @default(false)
  raidHistory    RaidHistory[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  element        Element       @relation(fields: [elementId], references: [id])
  elementId      Int
  body           AlienPart?    @relation("BodyPart", fields: [bodyId], references: [id])
  bodyId         Int?
  clothes        AlienPart?    @relation("ClothesPart", fields: [clothesId], references: [id])
  clothesId      Int?
  head           AlienPart?    @relation("HeadPart", fields: [headId], references: [id])
  headId         Int?
  eyes           AlienPart?    @relation("EyesPart", fields: [eyesId], references: [id])
  eyesId         Int?
  mouth          AlienPart?    @relation("MouthPart", fields: [mouthId], references: [id])
  mouthId        Int?
  hair           AlienPart?    @relation("HairPart", fields: [hairId], references: [id])
  hairId         Int?
  marks          AlienPart?    @relation("MarksPart", fields: [marksId], references: [id])
  marksId        Int?
  powers         AlienPart?    @relation("PowersPart", fields: [powersId], references: [id])
  powersId       Int?
  accessories    AlienPart?    @relation("AccessoriesPart", fields: [accessoriesId], references: [id])
  accessoriesId  Int?
}

model Element {
  id             Int              @id @default(autoincrement())
  name           String
  image          String
  background     String?
  aliens         Alien[]
  weakness       Element?         @relation("Strength", fields: [weaknessId], references: [id])
  weaknessId     Int?
  strength       Element?         @relation("Weakness", fields: [strengthId], references: [id])
  strengthId     Int?
  isDefault      Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  AlienPartGroup AlienPartGroup[]
  PackReward     PackReward[]
  characters     Character[]
  raids          Raid[]
  strengths      Element[]        @relation("Strength")
  weaknessess    Element[]        @relation("Weakness")
  UserElement    UserElement[]
}

enum CharacterRarity {
  R
  SR
  SSR
  UR
}

model Character {
  id                 Int                 @id @default(autoincrement())
  name               String
  rarity             CharacterRarity     @default(R)
  power              Int
  image              String?
  video              String?
  tokenId            Int
  upgradeReq         Int?
  upgradesToId       Int?
  tier               Int
  isPortal2          Boolean            @default(false)
  PackReward         PackReward[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  unmintedCharacters UnmintedCharacter[]
  element            Element             @relation(fields: [elementId], references: [id])
  elementId          Int
  gearItem           GearItem[]
}

model UnmintedCharacter {
  id          String    @id @default(uuid())
  userId      Int
  characterId Int
  status      TransactionStatus @default(INITIATED)
  user        User      @relation(fields: [userId], references: [id])
  character   Character @relation(fields: [characterId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())

  @@unique([userId, characterId])
  @@index([userId, characterId])
}

model UserElement {
  id        Int     @id @default(autoincrement())
  userId    Int
  elementId Int
  user      User    @relation(fields: [userId], references: [id])
  element   Element @relation(fields: [elementId], references: [id])
}

model Item {
  id          Int           @id @default(autoincrement())
  type        ItemType
  quality     ItemQuality
  description String
  image       String
  users       UserItem[]
  DailyReward DailyReward[]
}

model UserItem {
  id       Int  @id @default(autoincrement())
  userId   Int
  itemId   Int
  quantity Int
  user     User @relation(fields: [userId], references: [id])
  item     Item @relation(fields: [itemId], references: [id])

  @@index([userId, itemId])
}

enum GearItemRarity {
  COMMON
  UNCOMMON
  RARE
}

enum GearItemType {
  DANTE
  TWINS
  TEMBIN
  NIKOLA
  KARUSHI
  SHISHI
}

model GearItem {
  id                    Int           @id @default(autoincrement())
  rarity                GearItemRarity
  image                 String
  type                  GearItemType
  users                 UserGearItem[]
  summonedCharacter     Character?    @relation(fields: [summonedCharacterId], references: [id])
  summonedCharacterId   Int?
  dailyRewards  DailyReward[]
}

model UserGearItem {
  id         Int      @id @default(autoincrement())
  userId     Int
  gearItemId Int
  quantity   Int
  user       User     @relation(fields: [userId], references: [id])
  gearItem   GearItem @relation(fields: [gearItemId], references: [id])

  @@index([userId, gearItemId])
}

model DailyReward {
  id        Int             @id @default(autoincrement())
  type      DailyRewardType
  itemId    Int?
  amount    Int?
  item      Item?           @relation(fields: [itemId], references: [id])
  alienPartId Int?
  alienPart AlienPart?     @relation(fields: [alienPartId], references: [id])
  gearItemId Int?
  gearItem GearItem?       @relation(fields: [gearItemId], references: [id])
  rewardDate DateTime
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  User      User[]
}

model ReferralReward {
  id          Int      @id @default(autoincrement())
  referrer    User     @relation("ReferrerRewards", fields: [referrerId], references: [id])
  referrerId  Int
  referee     User     @relation("RefereeRewards", fields: [refereeId], references: [id])
  refereeId   Int
  starsEarned Int
  seen        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  @@index([referrerId])
  @@index([refereeId])
}

enum AlienPartType {
  BODY
  CLOTHES
  HEAD
  EYES
  MOUTH
  HAIR
  MARKS
  POWERS
  ACCESSORIES
}

model AlienPart {
  id             Int              @id @default(autoincrement())
  type           AlienPartType
  image          String
  name           String
  description    String?
  price          Float?
  power          Int              @default(0)
  isDefault      Boolean          @default(false)
  isForgeable   Boolean          @default(false)
  forgeRuneType RuneType?
  forgeRuneAmount Int?
  starBoost      Int              @default(0)
  xpBoost        Int              @default(0)
  raidTimeBoost  Int              @default(0)
  users          User[]
  packs          PackReward[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  transactions   Transaction[]
  AlienPartGroup AlienPartGroup[]
  dailyRewards   DailyReward[]
  bodyAliens        Alien[] @relation("BodyPart")
  clothesAliens     Alien[] @relation("ClothesPart")
  headAliens        Alien[] @relation("HeadPart")
  eyesAliens        Alien[] @relation("EyesPart")
  mouthAliens       Alien[] @relation("MouthPart")
  hairAliens        Alien[] @relation("HairPart")
  marksAliens       Alien[] @relation("MarksPart")
  powersAliens      Alien[] @relation("PowersPart")
  accessoriesAliens Alien[] @relation("AccessoriesPart")
}

model AlienPartGroup {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  parts       AlienPart[]
  element     Element?    @relation(fields: [elementId], references: [id])
  userId      Int?
  user        User?       @relation(fields: [userId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now())
  elementId   Int?
}

enum PackRewardType {
  STARS
  ALIEN_PARTS
  XP
  REP
  CHARACTER
  ELEMENT
}

model Pack {
  id           Int           @id @default(autoincrement())
  name         String
  description  String?
  image        String?
  price        Float
  isActive     Boolean       @default(true)
  rewards      PackReward[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  users        User[]        @relation("PurchasedPacks")
}

model PackReward {
  id          Int            @id @default(autoincrement())
  pack        Pack           @relation(fields: [packId], references: [id])
  packId      Int
  type        PackRewardType
  amount      Int?
  alienParts  AlienPart[]
  element     Element?       @relation(fields: [elementId], references: [id])
  character   Character?     @relation(fields: [characterId], references: [id])
  characterId Int?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  elementId   Int?

  @@index([packId])
}

model Transaction {
  id              Int               @id @default(autoincrement())
  user            User              @relation(fields: [userId], references: [id])
  userId          Int
  type            TransactionType
  amount          Float
  status          TransactionStatus @default(PENDING)
  stripePaymentId String?
  pack            Pack?             @relation(fields: [packId], references: [id])
  packId          Int?
  alienPart       AlienPart?        @relation(fields: [alienPartId], references: [id])
  alienPartId     Int?
  quantity        Int               @default(1)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId])
  @@index([stripePaymentId])
}

model CharacterTransaction {
  id              Int                      @id @default(autoincrement())
  type            CharacterTransactionType
  user            User                     @relation(fields: [userId], references: [id])
  userId          Int
  characterIds    Int[]
  status          TransactionStatus        @default(INITIATED)
  txHash          String?
  userWallet      String
  serverSignature String
  retries         Int                      @default(0)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([userId])
  @@index([txHash])
}

model UserSpin {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  result    Json
  createdAt DateTime @default(now())
}

model Quest {
  id             Int       @id @default(autoincrement())
  type           String
  frequency      String
  description    String
  requiredNumber Int
  rewards        Json
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  userQuests     UserQuest[]
}

model UserQuest {
  id             Int       @id @default(autoincrement())
  userId         Int
  questId        Int
  currentProgress Int      @default(0)
  isCompleted    Boolean   @default(false)
  isClaimed      Boolean   @default(false)
  user           User      @relation(fields: [userId], references: [id])
  quest          Quest     @relation(fields: [questId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Message {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int?
  content    String
  createdAt  DateTime @default(now())

  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User?    @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

model Friendship {
  id       Int  @id @default(autoincrement())
  userId   Int
  friendId Int

  user     User @relation("UserFriendships", fields: [userId], references: [id])
  friend   User @relation("FriendUserFriendships", fields: [friendId], references: [id])
}
