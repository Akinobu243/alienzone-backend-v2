generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum RewardType {
  STARS
  XP
}

enum DailyRewardType {
  ITEM
  STARS
  XP
}

enum RuneType {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum TransactionType {
  PACK
  ALIEN_PART
  STARS
  XP
  REP
}

enum Element {
  GAMMA
  FIRE
  LIFE
  WATER
  LOVE
  GRAVITY
  PLASMA
  THUNDER
}

enum ItemType {
  SHEARS
  CUT
  KNIFE
}

enum ItemQuality {
  BRONZE
  SILVER
  GOLDEN
}

model User {
  id               Int              @id @default(autoincrement())
  walletAddress    String           @unique
  name             String
  country          String
  twitterId        String
  enterprise       String
  referralCode     String           @unique
  referrerId       Int?
  image            String
  level            Int              @default(1)
  experience       Int
  reputation       Int
  stars            Int
  RaidHistory      RaidHistory[]
  aliens           Alien[]
  characters       UserCharacter[]
  items            UserItem[]
  runes            RuneType[]
  starsBoost       Int              @default(0)
  raidTimeBoost    Int              @default(0)
  xpBoost          Int              @default(0)
  lastStarBoost    DateTime?        
  lastRaidBoost    DateTime?        
  lastXpBoost      DateTime?        
  role             Role             @default(USER)
  dailyStreak      Int              @default(0)
  lastDailyClaimed DateTime         @default(now())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  referrerRewards  ReferralReward[] @relation("ReferrerRewards")
  refereeRewards   ReferralReward[] @relation("RefereeRewards")
  alienParts       UserAlienPart[]
  transactions     Transaction[]
}

model Raid {
  id          Int           @id @default(autoincrement())
  title       String
  description String
  duration    Int
  icon        String
  image       String
  type        Element
  rewards     RaidReward[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  RaidHistory RaidHistory[]
}

model RaidReward {
  id        Int        @id @default(autoincrement())
  type      RewardType
  amount    Int
  raids     Raid[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model RaidHistory {
  id         Int             @id @default(autoincrement())
  raid       Raid            @relation(fields: [raidId], references: [id])
  raidId     Int
  user       User            @relation(fields: [userId], references: [id])
  userId     Int
  aliens     Alien[]
  characters UserCharacter[]
  inProgress Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([raidId, userId])
}

model Alien {
  id             Int           @id @default(autoincrement())
  name           String
  element        Element
  image          String?
  strengthPoints Int
  user           User          @relation(fields: [userId], references: [id])
  userId         Int
  inRaid         Boolean
  raidHistory    RaidHistory[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Character {
  id             Int             @id @default(autoincrement())
  name           String
  element        Element
  strengthPoints Int
  level          Int
  image          String
  portal         Int
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  users          UserCharacter[]
}

model UserCharacter {
  id          Int           @id @default(autoincrement())
  userId      Int
  characterId Int
  inRaid      Boolean       @default(false)
  user        User          @relation(fields: [userId], references: [id])
  character   Character     @relation(fields: [characterId], references: [id])
  raidHistory RaidHistory[]

  @@index([userId, characterId])
}

model Item {
  id          Int           @id @default(autoincrement())
  type        ItemType
  quality     ItemQuality
  description String
  image       String
  users       UserItem[]
  DailyReward DailyReward[]
}

model UserItem {
  id       Int  @id @default(autoincrement())
  userId   Int
  itemId   Int
  quantity Int
  user     User @relation(fields: [userId], references: [id])
  item     Item @relation(fields: [itemId], references: [id])

  @@index([userId, itemId])
}

model DailyReward {
  id        Int             @id @default(autoincrement())
  type      DailyRewardType
  itemId    Int?
  amount    Int?
  item      Item?           @relation(fields: [itemId], references: [id])
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model ReferralReward {
  id          Int      @id @default(autoincrement())
  referrer    User     @relation("ReferrerRewards", fields: [referrerId], references: [id])
  referrerId  Int
  referee     User     @relation("RefereeRewards", fields: [refereeId], references: [id])
  refereeId   Int
  starsEarned Int
  seen        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([referrerId])
  @@index([refereeId])
}

enum AlienPartType {
  BODY
  CLOTHES
  HEAD
  FACE
  HAIR
}

model UserAlienPart {
  id          Int       @id @default(autoincrement())
  userId      Int
  alienPartId Int
  user        User      @relation(fields: [userId], references: [id])
  alienPart   AlienPart @relation(fields: [alienPartId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, alienPartId])
}

model AlienPart {
  id           Int             @id @default(autoincrement())
  type         AlienPartType
  image        String
  name         String
  description  String?
  price        Int?
  isDefault    Boolean         @default(false)
  users        UserAlienPart[]
  packs        PackReward[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  transactions Transaction[]
}

enum PackRewardType {
  STARS
  ALIEN_PART
  XP
  REP
}

model Pack {
  id           Int           @id @default(autoincrement())
  name         String
  description  String?
  image        String?
  price        Int
  isActive     Boolean       @default(true)
  rewards      PackReward[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model PackReward {
  id          Int            @id @default(autoincrement())
  pack        Pack           @relation(fields: [packId], references: [id])
  packId      Int
  type        PackRewardType
  amount      Int?
  alienPart   AlienPart?     @relation(fields: [alienPartId], references: [id])
  alienPartId Int?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([packId])
  @@index([alienPartId])
}

model Transaction {
  id              Int               @id @default(autoincrement())
  user            User              @relation(fields: [userId], references: [id])
  userId          Int
  type            TransactionType
  amount          Float
  status          TransactionStatus @default(PENDING)
  stripePaymentId String?
  pack            Pack?             @relation(fields: [packId], references: [id])
  packId          Int?
  alienPart       AlienPart?        @relation(fields: [alienPartId], references: [id])
  alienPartId     Int?
  quantity        Int               @default(1)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId])
  @@index([stripePaymentId])
}
