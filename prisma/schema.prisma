generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum RewardType {
  STARS
  XP
  REP
}

enum DailyRewardType {
  ITEM
  STARS
  XP
}

model User {
  id               Int             @id @default(autoincrement())
  walletAddress    String          @unique
  name             String
  country          String
  twitterId        String
  enterprise       String
  image            String
  level            Int
  experience       Int
  reputation       Int
  stars            Int
  RaidHistory      RaidHistory[]
  aliens           Alien[]
  characters       UserCharacter[]
  items            UserItem[]
  role             Role            @default(USER)
  dailyStreak      Int             @default(0)
  lastDailyClaimed DateTime        @default(now())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Raid {
  id          Int           @id @default(autoincrement())
  title       String
  description String
  duration    Int
  rewards     RaidReward[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  RaidHistory RaidHistory[]
}

model RaidReward {
  id        Int        @id @default(autoincrement())
  raid      Raid       @relation(fields: [raidId], references: [id])
  raidId    Int
  type      RewardType
  amount    Int
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([raidId])
}

model RaidHistory {
  id         Int             @id @default(autoincrement())
  raid       Raid            @relation(fields: [raidId], references: [id])
  raidId     Int
  user       User            @relation(fields: [userId], references: [id])
  userId     Int
  aliens     Alien[]
  characters UserCharacter[]
  inProgress Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([raidId, userId])
}

model Alien {
  id             Int           @id @default(autoincrement())
  name           String
  element        String
  image          String?
  strengthPoints Int
  user           User          @relation(fields: [userId], references: [id])
  userId         Int
  inRaid         Boolean
  raidHistory    RaidHistory[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Character {
  id             Int             @id @default(autoincrement())
  name           String
  element        String
  strengthPoints Int
  level          Int
  image          String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  users          UserCharacter[]
}

model UserCharacter {
  id          Int           @id @default(autoincrement())
  userId      Int
  characterId Int
  inRaid      Boolean       @default(false)
  user        User          @relation(fields: [userId], references: [id])
  character   Character     @relation(fields: [characterId], references: [id])
  raidHistory RaidHistory[]

  @@index([userId, characterId])
}

model Item {
  id          Int           @id @default(autoincrement())
  name        String
  description String
  image       String
  users       UserItem[]
  DailyReward DailyReward[]
}

model UserItem {
  id       Int  @id @default(autoincrement())
  userId   Int
  itemId   Int
  quantity Int
  user     User @relation(fields: [userId], references: [id])
  item     Item @relation(fields: [itemId], references: [id])

  @@index([userId, itemId])
}

model DailyReward {
  id        Int             @id @default(autoincrement())
  type      DailyRewardType
  itemId    Int?
  amount    Int?
  item      Item?           @relation(fields: [itemId], references: [id])
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}
