generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum RewardType {
  STARS
  XP
}

enum DailyRewardType {
  ITEM
  STARS
  XP
}

enum RuneType {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum TransactionType {
  PACK
  ALIEN_PART
  STARS
  XP
  REP
}

enum ElementType {
  GAMMA
  FIRE
  LIFE
  WATER
  LOVE
  GRAVITY
  PLASMA
  THUNDER
}

enum ItemType {
  SHEARS
  CUT
  KNIFE
}

enum ItemQuality {
  BRONZE
  SILVER
  GOLDEN
}

model User {
  id               Int              @id @default(autoincrement())
  walletAddress    String           @unique
  name             String
  country          String
  twitterId        String
  enterprise       String
  referralCode     String           @unique
  referrerId       Int?
  image            String
  level            Int              @default(1)
  experience       Int
  reputation       Int
  stars            Int
  RaidHistory      RaidHistory[]
  aliens           Alien[]
  characters       UserCharacter[]
  items            UserItem[]
  runes            RuneType[]
  starsBoost       Int              @default(0)
  raidTimeBoost    Int              @default(0)
  xpBoost          Int              @default(0)
  lastStarBoost    DateTime?
  lastRaidBoost    DateTime?
  lastXpBoost      DateTime?
  role             Role             @default(USER)
  dailyStreak      Int              @default(0)
  lastDailyClaimed DateTime         @default(now())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  referrerRewards  ReferralReward[] @relation("ReferrerRewards")
  refereeRewards   ReferralReward[] @relation("RefereeRewards")
  transactions     Transaction[]
  AlienParts       AlienPart[]
  purchasedPacks   Pack[]           @relation("PurchasedPacks")
  gearItems        UserGearItem[]
  UserElement      UserElement[]
}

model Raid {
  id          Int           @id @default(autoincrement())
  title       String
  description String
  duration    Int
  icon        String
  image       String
  rewards     RaidReward[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  RaidHistory RaidHistory[]
  element     Element       @relation(fields: [elementId], references: [id])
  elementId   Int
}

model RaidReward {
  id        Int        @id @default(autoincrement())
  type      RewardType
  amount    Int
  raids     Raid[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model RaidHistory {
  id         Int             @id @default(autoincrement())
  raid       Raid            @relation(fields: [raidId], references: [id])
  raidId     Int
  user       User            @relation(fields: [userId], references: [id])
  userId     Int
  aliens     Alien[]
  characters UserCharacter[]
  inProgress Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([raidId, userId])
}

model Alien {
  id             Int           @id @default(autoincrement())
  name           String
  image          String?
  strengthPoints Int
  user           User          @relation(fields: [userId], references: [id])
  userId         Int
  inRaid         Boolean
  onTeam         Boolean       @default(false)
  selected       Boolean       @default(false)
  raidHistory    RaidHistory[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  element        Element       @relation(fields: [elementId], references: [id])
  elementId      Int
}

model Element {
  id             Int              @id @default(autoincrement())
  name           String
  image          String
  background     String?
  aliens         Alien[]
  weakness       Element?         @relation("Strength", fields: [weaknessId], references: [id])
  weaknessId     Int?
  strength       Element?         @relation("Weakness", fields: [strengthId], references: [id])
  strengthId     Int?
  isDefault      Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  AlienPartGroup AlienPartGroup[]
  PackReward     PackReward[]
  characters     Character[]
  raids          Raid[]
  strengths      Element[]        @relation("Strength")
  weaknessess    Element[]        @relation("Weakness")
  UserElement    UserElement[]
}

enum CharacterRarity {
  SR
}

model Character {
  id         Int             @id @default(autoincrement())
  name       String
  rarity     CharacterRarity @default(SR)
  power      Int
  image      String?
  video      String?
  portal     Int
  PackReward PackReward[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  users      UserCharacter[]
  element    Element         @relation(fields: [elementId], references: [id])
  elementId  Int
  gearItem   GearItem[]
}

model UserCharacter {
  id          Int           @id @default(autoincrement())
  userId      Int
  characterId Int
  quantity    Int           @default(1)
  inRaid      Boolean       @default(false)
  onTeam      Boolean       @default(false)
  user        User          @relation(fields: [userId], references: [id])
  character   Character     @relation(fields: [characterId], references: [id])
  raidHistory RaidHistory[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([userId, characterId])
  @@index([userId, characterId])
}

model UserElement {
  id        Int     @id @default(autoincrement())
  userId    Int
  elementId Int
  user      User    @relation(fields: [userId], references: [id])
  element   Element @relation(fields: [elementId], references: [id])
}

model Item {
  id          Int           @id @default(autoincrement())
  type        ItemType
  quality     ItemQuality
  description String
  image       String
  users       UserItem[]
  DailyReward DailyReward[]
}

model UserItem {
  id       Int  @id @default(autoincrement())
  userId   Int
  itemId   Int
  quantity Int
  user     User @relation(fields: [userId], references: [id])
  item     Item @relation(fields: [itemId], references: [id])

  @@index([userId, itemId])
}

enum GearItemRarity {
  COMMON
  UNCOMMON
  RARE
}

model GearItem {
  id                    Int           @id @default(autoincrement())
  rarity                GearItemRarity
  image                 String
  users                 UserGearItem[]
  summonedCharacter     Character?    @relation(fields: [summonedCharacterId], references: [id])
  summonedCharacterId   Int?
}

model UserGearItem {
  id            Int  @id @default(autoincrement())
  userId        Int
  gearItemId    Int
  quantity      Int
  user          User @relation(fields: [userId], references: [id])
  gearItem      GearItem @relation(fields: [gearItemId], references: [id])

  @@index([userId, gearItemId])
}

model DailyReward {
  id        Int             @id @default(autoincrement())
  type      DailyRewardType
  itemId    Int?
  amount    Int?
  item      Item?           @relation(fields: [itemId], references: [id])
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model ReferralReward {
  id          Int      @id @default(autoincrement())
  referrer    User     @relation("ReferrerRewards", fields: [referrerId], references: [id])
  referrerId  Int
  referee     User     @relation("RefereeRewards", fields: [refereeId], references: [id])
  refereeId   Int
  starsEarned Int
  seen        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([referrerId])
  @@index([refereeId])
}

enum AlienPartType {
  BODY
  CLOTHES
  HEAD
  EYES
  MOUTH
  HAIR
  MARKS
  POWERS
  ACCESSORIES
  FACE
}

model AlienPart {
  id             Int              @id @default(autoincrement())
  type           AlienPartType
  image          String
  name           String
  description    String?
  price          Float?
  isDefault      Boolean          @default(false)
  users          User[]
  packs          PackReward[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  transactions   Transaction[]
  AlienPartGroup AlienPartGroup[]
}

model AlienPartGroup {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  parts       AlienPart[]
  element     Element?    @relation(fields: [elementId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  elementId   Int?
}

enum PackRewardType {
  STARS
  ALIEN_PARTS
  XP
  REP
  CHARACTER
  ELEMENT
}

model Pack {
  id           Int           @id @default(autoincrement())
  name         String
  description  String?
  image        String?
  price        Float
  isActive     Boolean       @default(true)
  rewards      PackReward[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  users        User[]        @relation("PurchasedPacks")
}

model PackReward {
  id          Int            @id @default(autoincrement())
  pack        Pack           @relation(fields: [packId], references: [id])
  packId      Int
  type        PackRewardType
  amount      Int?
  alienParts  AlienPart[]
  element     Element?       @relation(fields: [elementId], references: [id])
  character   Character?     @relation(fields: [characterId], references: [id])
  characterId Int?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  elementId   Int?

  @@index([packId])
}

model Transaction {
  id              Int               @id @default(autoincrement())
  user            User              @relation(fields: [userId], references: [id])
  userId          Int
  type            TransactionType
  amount          Float
  status          TransactionStatus @default(PENDING)
  stripePaymentId String?
  pack            Pack?             @relation(fields: [packId], references: [id])
  packId          Int?
  alienPart       AlienPart?        @relation(fields: [alienPartId], references: [id])
  alienPartId     Int?
  quantity        Int               @default(1)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId])
  @@index([stripePaymentId])
}
